# ─────────────────────────────────────────────────────────────────
# .dockerignore — keeps the Docker build context small.
# Anything listed here is NOT sent to the Docker daemon when building.
# Without this file, the build context was ~815 MB and caused
# `exit code 255` failures during the image-export step on Coolify.
# ─────────────────────────────────────────────────────────────────

# ── dependencies (Docker reinstalls these inside the image) ──
node_modules
.pnp
.pnp.*
.yarn

# ── next.js build outputs (rebuilt inside the image) ──
.next
out
build

# ── git history (not needed at runtime) ──
.git
.gitignore
.gitattributes

# ── editor / IDE ──
.vscode
.idea
*.swp
*.swo
.DS_Store
Thumbs.db

# ── env files (provided via Coolify env vars, never bake into image) ──
.env
.env.*
.env*.local

# ── logs ──
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ── testing / coverage ──
coverage
.nyc_output

# ── TypeScript build cache ──
*.tsbuildinfo
next-env.d.ts

# ── deployment platform metadata ──
.vercel
.netlify

# ── docs / readmes (not needed in production image) ──
HANDOFF.md
README.md
*.md

# ── Excel work files dropped in the project root by the team ──
*.xlsx
*.xls
样本_*

# ── CRM 部署文件夹 — 独立的 xmchic-crm 仓库，不属于 new-website ──
crm-deploy/

# ── Docker / CI files (not needed inside the image) ──
.dockerignore
Dockerfile*
docker-compose*.yml
.github
.gitlab-ci.yml

# ── temp / cache ──
.cache
tmp
temp
*.tmp
